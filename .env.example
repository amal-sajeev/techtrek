# Copy this file to .env and fill in real values before running the app.
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=replace_with_64_hex_chars_minimum_32

# Database URL
# PostgreSQL: postgresql+psycopg2://user:password@localhost:5432/techtrek
# SQLite (dev): sqlite:///./techtrek.db
DATABASE_URL=postgresql+psycopg2://postgres:yourpassword@localhost:5432/techtrek

# Razorpay payment gateway (get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# First admin user email. Only this email will receive admin on registration.
# Leave empty to use first-registrant-wins (dev only).
ADMIN_BOOTSTRAP_EMAIL=admin@yourdomain.com

# Invoice / Company details
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=Your Address
COMPANY_GSTIN=
COMPANY_PAN=
COMPANY_EMAIL=billing@yourdomain.com
COMPANY_PHONE=
GST_RATE=18

# SMTP (email sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=YourApp
